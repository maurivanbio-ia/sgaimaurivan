          },
          "position": [450, 300]
        },
        {
          "name": "Send Summary",
          "type": "n8n-nodes-base.emailSend",
          "parameters": {
            "fromEmail": "relatorios@ecobrasil.bio.br",
            "toEmail": "coordenadores@ecobrasil.bio.br",
            "subject": "Bom dia! Seu resumo diário - EcoGestor",
            "html": "<h2>Resumo do Dia</h2><h3>Suas Demandas</h3><ul><li>Pendentes: {{$json.demandasPendentes}}</li><li>Em andamento: {{$json.demandasEmAndamento}}</li><li>Atrasadas: {{$json.demandasAtrasadas}}</li></ul><h3>Sua Equipe</h3><ul><li>Tarefas ativas: {{$json.tarefasEquipe}}</li><li>Colaboradores: {{$json.totalColaboradores}}</li></ul><h3>Alertas</h3><ul><li>Licenças vencendo: {{$json.licencasVencendo}}</li><li>Condicionantes: {{$json.condicionantesPendentes}}</li></ul>"
          },
          "position": [650, 300]
        }
      ],
      "connections": {
        "Schedule Trigger": { "main": [[{ "node": "HTTP Request", "type": "main", "index": 0 }]] },
        "HTTP Request": { "main": [[{ "node": "Send Summary", "type": "main", "index": 0 }]] }
      }
    },
    {
      "name": "EcoGestor - Health Check",
      "nodes": [
        {
          "name": "Schedule Trigger",
          "type": "n8n-nodes-base.scheduleTrigger",
          "parameters": {
            "rule": {
              "interval": [{ "field": "minutes", "minutesInterval": 5 }]
            }
          },
          "position": [250, 300]
        },
        {
          "name": "HTTP Request",
          "type": "n8n-nodes-base.httpRequest",
          "parameters": {
            "method": "GET",
            "url": "={{$env.ECOGESTOR_URL}}/api/webhooks/n8n/health",
            "authentication": "genericCredentialType",
            "genericAuthType": "httpHeaderAuth",
            "options": {
              "timeout": 10000
            }
          },
          "position": [450, 300],
          "continueOnFail": true
        },
        {
          "name": "Check Status",
          "type": "n8n-nodes-base.if",
          "parameters": {
            "conditions": {
              "string": [{ "value1": "={{$json.status}}", "operation": "notEqual", "value2": "ok" }]
            }
          },
          "position": [650, 300]
        },
        {
          "name": "Send Alert TI",
          "type": "n8n-nodes-base.emailSend",
          "parameters": {
            "fromEmail": "monitoramento@ecobrasil.bio.br",
            "toEmail": "ti@ecobrasil.bio.br",
            "subject": "ALERTA: EcoGestor está fora do ar!",
            "text": "O sistema EcoGestor não respondeu ao health check.\n\nHora: {{$now.toISO()}}\n\nVerifique imediatamente!"
          },
          "position": [850, 200]
        }
      ],
      "connections": {
        "Schedule Trigger": { "main": [[{ "node": "HTTP Request", "type": "main", "index": 0 }]] },
        "HTTP Request": { "main": [[{ "node": "Check Status", "type": "main", "index": 0 }]] },
        "Check Status": { "main": [[{ "node": "Send Alert TI", "type": "main", "index": 0 }], []] }
      }
    }
  ],
  "credentials": {
    "httpHeaderAuth": {
      "name": "EcoGestor API Key",
      "type": "httpHeaderAuth",
      "data": {
        "name": "N8N_API_KEY",
        "value": "EcoBrasil2024SecureKey!"
      }
    }
  },
  "variables": {
    "ECOGESTOR_URL": "https://sua-url-replit.replit.app"
  }
}
