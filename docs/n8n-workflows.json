    {
      "name": "EcoGestor - Tarefas Pendentes",
      "nodes": [
        {
          "name": "Schedule Trigger",
          "type": "n8n-nodes-base.scheduleTrigger",
          "parameters": {
            "rule": {
              "interval": [{ "field": "cronExpression", "expression": "0 9 * * 1-5" }]
            }
          },
          "position": [250, 300]
        },
        {
          "name": "HTTP Request",
          "type": "n8n-nodes-base.httpRequest",
          "parameters": {
            "method": "GET",
            "url": "={{$env.ECOGESTOR_URL}}/api/webhooks/n8n/tasks",
            "authentication": "genericCredentialType",
            "genericAuthType": "httpHeaderAuth"
          },
          "position": [450, 300]
        },
        {
          "name": "Split Tasks",
          "type": "n8n-nodes-base.splitInBatches",
          "parameters": {
            "batchSize": 1
          },
          "position": [650, 300]
        },
        {
          "name": "Send Task Reminder",
          "type": "n8n-nodes-base.emailSend",
          "parameters": {
            "fromEmail": "alertas@ecobrasil.bio.br",
            "toEmail": "={{$json.responsavelEmail}}",
            "subject": "Lembrete: Tarefa pendente - {{$json.titulo}}",
            "text": "Você tem uma tarefa pendente:\n\nTítulo: {{$json.titulo}}\nPrazo: {{$json.prazo}}\nPrioridade: {{$json.prioridade}}\n\nAcesse o sistema para mais detalhes."
          },
          "position": [850, 300]
        }
      ],
      "connections": {
        "Schedule Trigger": { "main": [[{ "node": "HTTP Request", "type": "main", "index": 0 }]] },
        "HTTP Request": { "main": [[{ "node": "Split Tasks", "type": "main", "index": 0 }]] },
        "Split Tasks": { "main": [[{ "node": "Send Task Reminder", "type": "main", "index": 0 }]] }
      }
    },
    {
      "name": "EcoGestor - Dashboard Coordenador",
      "nodes": [
        {
          "name": "Schedule Trigger",
          "type": "n8n-nodes-base.scheduleTrigger",
          "parameters": {
            "rule": {
              "interval": [{ "field": "cronExpression", "expression": "30 7 * * 1-5" }]
