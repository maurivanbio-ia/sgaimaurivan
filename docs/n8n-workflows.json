{
  "workflows": [
    {
      "name": "EcoGestor - Alertas de Licenças",
      "nodes": [
        {
          "name": "Schedule Trigger",
          "type": "n8n-nodes-base.scheduleTrigger",
          "parameters": {
            "rule": {
              "interval": [{ "field": "cronExpression", "expression": "0 8 * * *" }]
            }
          },
          "position": [250, 300]
        },
        {
          "name": "HTTP Request",
          "type": "n8n-nodes-base.httpRequest",
          "parameters": {
            "method": "GET",
            "url": "={{$env.ECOGESTOR_URL}}/api/webhooks/n8n/licenses",
            "authentication": "genericCredentialType",
            "genericAuthType": "httpHeaderAuth",
            "options": {}
          },
          "position": [450, 300]
        },
        {
          "name": "IF",
          "type": "n8n-nodes-base.if",
          "parameters": {
            "conditions": {
              "number": [{ "value1": "={{$json.total}}", "operation": "larger", "value2": 0 }]
            }
          },
          "position": [650, 300]
        },
        {
          "name": "Send Email",
          "type": "n8n-nodes-base.emailSend",
          "parameters": {
            "fromEmail": "alertas@ecobrasil.bio.br",
            "toEmail": "licencas@ecobrasil.bio.br",
            "subject": "Alerta: {{$json.total}} Licenças Próximas do Vencimento",
            "text": "Existem {{$json.total}} licenças que vencem nos próximos 30 dias.\n\nAcesse o sistema para mais detalhes."
          },
          "position": [850, 200]
        }
      ],
      "connections": {
        "Schedule Trigger": { "main": [[{ "node": "HTTP Request", "type": "main", "index": 0 }]] },
        "HTTP Request": { "main": [[{ "node": "IF", "type": "main", "index": 0 }]] },
        "IF": { "main": [[{ "node": "Send Email", "type": "main", "index": 0 }], []] }
      }
    },
